{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://agri-backend.onrender.com/:path*"
    },
    {
      "source": "/((?!assets|favicon.ico|noise.svg).*)" ,
      "destination": "/index.html"
    }
  ]
}
