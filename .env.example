# Core API Keys
GOOGLE_API_KEY=your_gemini_api_key_here
OPENWEATHER_API_KEY=your_openweather_key_here

# Database Configuration (Supabase or Local)
DATABASE_URL=postgresql://postgres:[password]@db.supabase.com:5432/postgres

# Redis Configuration (Upstash or Local)
REDIS_URL=rediss://default:[password]@your-redis-instance.upstash.io:6379

# Backend Settings
DEBUG=True
SECRET_KEY=generate_a_secure_random_key_for_production

# Frontend API Integration (Vite)
VITE_API_URL=https://your-backend-url.railway.app
VITE_WS_URL=wss://your-backend-url.railway.app/ws/agent-feed

# Billing (Phase 5)
RAZORPAY_KEY_ID=your_razorpay_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
STRIPE_SECRET_KEY=your_stripe_key
